# Backend API base URL (no trailing slash).
# For Railway, point this at your roles-api public URL.
VITE_API_URL=http://localhost:4000

# Static API token. Must match API_TOKEN on the backend.
# Sent as `Authorization: Bearer <token>` on every request.
VITE_API_TOKEN=dev-token-please-change-me-1234567890

VITE_APP_VERSION=1.0.0
